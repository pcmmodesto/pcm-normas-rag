NEXT_PUBLIC_APP_NAME="PCM Normas RAG"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Supabase public project URL, not a database URL.
# Example: https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=""
SUPABASE_URL=""

# Supabase client key for browser/server code with RLS.
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_ANON_KEY=""

# Supabase privileged server-only key. Never expose this in the browser.
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_DOCUMENTS_BUCKET="technical-documents"

# Comma-separated e-mails that should receive ADMIN role after Supabase login.
# Example: ADMIN_EMAILS="admin@example.com,owner@example.com"
ADMIN_EMAILS=""

# PostgreSQL / Prisma / pgvector
# Local development: use a direct PostgreSQL URL.
# Vercel/serverless runtime: prefer the Supabase transaction pooler for DATABASE_URL.
# Migrations: use DIRECT_URL with the direct connection string.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pcm_normas_rag?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/pcm_normas_rag?schema=public"
SHADOW_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pcm_normas_rag_shadow?schema=public"
PGVECTOR_DIMENSIONS="1536"

# Visual extraction provider. Anthropic is preferred when both keys are present.
ANTHROPIC_API_KEY=""
ANTHROPIC_EXTRACTION_MODEL="claude-sonnet-4-20250514"

# Optional OpenAI fallback for visual extraction.
OPENAI_API_KEY=""
OPENAI_EXTRACTION_MODEL="gpt-4.1-mini"

# This file contains placeholders only. Do not commit real secrets.
