generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  MEMBER
  VIEWER

  @@map("user_role")
}

enum CompanyMemberRole {
  OWNER
  ADMIN
  ENGINEER
  ANALYST
  VIEWER

  @@map("company_member_role")
}

enum CompanyStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED

  @@map("company_status")
}

enum SubscriptionPlan {
  FREE
  PRO
  BUSINESS
  ENTERPRISE

  @@map("subscription_plan")
}

enum DocumentScope {
  GLOBAL
  COMPANY

  @@map("document_scope")
}

enum DocumentAudience {
  PUBLIC_CLIENT
  TECHNICAL
  BOTH

  @@map("document_audience")
}

enum DocumentCategory {
  BAIXA_TENSAO
  MEDIA_TENSAO
  ALTA_TENSAO
  LIGACAO_NOVA
  PADRAO_ENTRADA
  SUBESTACAO
  REDE_DISTRIBUICAO
  REDE_AEREA
  REDE_SUBTERRANEA
  GERACAO_DISTRIBUIDA
  ESPECIFICACAO_MATERIAL
  NOTA_TECNICA
  EPD
  EPE
  MANUAL
  PROCEDIMENTO
  TABELA_TECNICA
  ABACO
  OUTRO

  @@map("document_category")
}

enum TechnicalDocumentType {
  TECHNICAL_STANDARD
  CONNECTION_STANDARD
  PROCEDURE
  MANUAL
  RESOLUTION
  OTHER

  @@map("technical_document_type")
}

enum DocumentStatus {
  DRAFT
  ACTIVE
  ARCHIVED

  @@map("document_status")
}

enum VersionStatus {
  DRAFT
  PROCESSING
  READY
  FAILED
  ARCHIVED

  @@map("version_status")
}

enum ProcessingStatus {
  PENDING
  EXTRACTING
  CHUNKING
  EMBEDDING
  READY
  FAILED

  @@map("processing_status")
}

enum RagQuestionStatus {
  RECEIVED
  RETRIEVING
  ANSWERING
  ANSWERED
  FAILED

  @@map("rag_question_status")
}

enum RagAnswerStatus {
  DRAFT
  COMPLETED
  FAILED

  @@map("rag_answer_status")
}

enum QuestionAudience {
  CLIENT
  TECHNICAL
  UNKNOWN

  @@map("question_audience")
}

enum QuestionComplexity {
  SIMPLE
  INTERMEDIATE
  ADVANCED

  @@map("question_complexity")
}

enum AccessLevel {
  FREE
  PAID_SINGLE
  PAID_SUBSCRIPTION
  INTERNAL_ADMIN

  @@map("access_level")
}

enum BillingProduct {
  FREE_BT
  TECHNICAL_SINGLE_QUERY
  TECHNICAL_MONTHLY
  TECHNICAL_ANNUAL

  @@map("billing_product")
}

enum QueryType {
  BASIC_INFO
  STEP_BY_STEP
  DOCUMENT_LIST
  TECHNICAL_CRITERIA
  DIMENSIONING
  TABLE_LOOKUP
  ABACO_LOOKUP
  MATERIAL_SPECIFICATION
  NETWORK_STRUCTURE
  SUBSTATION
  REGULATORY_INTERPRETATION
  UNKNOWN

  @@map("query_type")
}

enum AnswerStatus {
  DRAFT
  GENERATED
  NEEDS_MORE_CONTEXT
  INSUFFICIENT_SOURCE
  VALIDATED
  FLAGGED
  REJECTED

  @@map("answer_status")
}

enum ChunkType {
  TEXT
  SECTION
  TABLE
  TABLE_ROW
  DEFINITION
  REQUIREMENT
  PROCEDURE
  FORMULA
  ANNEX
  HEADER_FOOTER
  SUMMARY
  ADMINISTRATIVE
  NORMATIVE_DRAWING
  NORMATIVE_TABLE
  NORMATIVE_NOTE
  PAGE_HEADER

  @@map("chunk_type")
}

enum BillingInterval {
  NONE
  SINGLE
  MONTH
  YEAR

  @@map("billing_interval")
}

enum SubscriptionStatus {
  INCOMPLETE
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID

  @@map("subscription_status")
}

enum QueryCreditSource {
  PURCHASE
  SUBSCRIPTION
  ADMIN_GRANT
  PROMOTION

  @@map("query_credit_source")
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  CANCELED

  @@map("payment_status")
}

enum TechnicalRuleSourceType {
  TABLE
  ABACUS
  CHUNK
  DOCUMENT
  MANUAL_REVIEW

  @@map("technical_rule_source_type")
}

enum TechnicalRuleStatus {
  DRAFT
  REVIEW_REQUIRED
  VALIDATED
  ARCHIVED

  @@map("technical_rule_status")
}

enum AnswerFeedbackType {
  HELPFUL
  INCORRECT
  MISSING_SOURCE
  UNSAFE_TECHNICAL
  OUTDATED_NORM
  OTHER

  @@map("answer_feedback_type")
}

enum ValidationStatus {
  DRAFT
  REVIEWED
  VALIDATED
  REJECTED
  ARCHIVED

  @@map("validation_status")
}

enum NormativeAssetType {
  TABLE
  FIGURE
  DRAWING
  NOTE
  LEGEND
  REQUIREMENT

  @@map("normative_asset_type")
}

enum NormativeAssetValidationStatus {
  PENDING
  VALIDATED
  REJECTED
  NEEDS_REVIEW

  @@map("normative_asset_validation_status")
}

enum AuditAction {
  USER_LOGIN
  DOCUMENT_CREATED
  DOCUMENT_UPDATED
  DOCUMENT_VERSION_CREATED
  DOCUMENT_PROCESSED
  RAG_QUESTION_CREATED
  RAG_ANSWER_CREATED
  PLAN_USAGE_RECORDED
  SYSTEM_EVENT

  @@map("audit_action")
}

enum UsageMetric {
  RAG_QUESTION
  DOCUMENT_UPLOAD
  DOCUMENT_PAGE
  DOCUMENT_CHUNK
  STORAGE_MB
  EMBEDDING_TOKEN
  CHAT_TOKEN

  @@map("usage_metric")
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String?
  role           UserRole  @default(MEMBER)
  avatarUrl      String?   @map("avatar_url")
  externalAuthId String?   @unique @map("external_auth_id")
  isActive       Boolean   @default(true) @map("is_active")
  lastLoginAt    DateTime? @map("last_login_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  companyMemberships CompanyMember[]
  uploadedVersions   DocumentVersion[] @relation("DocumentVersionUploader")
  ragQuestions       RagQuestion[]
  auditLogs          AuditLog[]
  subscriptions      UserSubscription[]
  queryCredits       QueryCredit[]
  paidQueryPurchases PaidQueryPurchase[]
  answerFeedbacks    AnswerFeedback[]
  validatedAnswers   ValidatedAnswer[]  @relation("ValidatedAnswerReviewer")
  validatedNormativeAssets NormativeAsset[] @relation("NormativeAssetValidator")

  @@index([email])
  @@map("users")
}

model Company {
  id             String           @id @default(cuid())
  name           String
  legalName      String?          @map("legal_name")
  documentNumber String?          @unique @map("document_number")
  slug           String           @unique
  status         CompanyStatus    @default(ACTIVE)
  plan           SubscriptionPlan @default(FREE)
  stateCodes     String[]         @default([]) @map("state_codes")
  metadata       Json             @default("{}")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  members            CompanyMember[]
  technicalDocuments TechnicalDocument[]
  ragQuestions       RagQuestion[]
  auditLogs          AuditLog[]
  planUsages         PlanUsage[]
  subscriptions      UserSubscription[]
  queryCredits       QueryCredit[]
  paidQueryPurchases PaidQueryPurchase[]

  @@index([slug])
  @@index([status, plan])
  @@map("companies")
}

model CompanyMember {
  id        String            @id @default(cuid())
  companyId String            @map("company_id")
  userId    String            @map("user_id")
  role      CompanyMemberRole @default(VIEWER)
  title     String?
  isActive  Boolean           @default(true) @map("is_active")
  invitedAt DateTime?         @map("invited_at")
  joinedAt  DateTime?         @map("joined_at")
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId])
  @@index([userId])
  @@index([companyId, role])
  @@map("company_members")
}

model TechnicalDocument {
  id             String                @id @default(cuid())
  companyId      String?               @map("company_id")
  scope          DocumentScope         @default(COMPANY)
  title          String
  slug           String
  description    String?
  concessionaire String?
  stateCodes     String[]              @default([]) @map("state_codes")
  documentType   TechnicalDocumentType @default(TECHNICAL_STANDARD) @map("document_type")
  audience       DocumentAudience      @default(BOTH)
  categories     DocumentCategory[]    @default([])
  status         DocumentStatus        @default(DRAFT)
  tags           String[]              @default([])
  metadata       Json                  @default("{}")
  createdAt      DateTime              @default(now()) @map("created_at")
  updatedAt      DateTime              @updatedAt @map("updated_at")

  company   Company?          @relation(fields: [companyId], references: [id], onDelete: SetNull)
  versions  DocumentVersion[]
  questions RagQuestion[]

  @@unique([companyId, slug])
  @@index([scope, status])
  @@index([concessionaire])
  @@index([documentType])
  @@index([audience])
  @@map("technical_documents")
}

model DocumentVersion {
  id               String           @id @default(cuid())
  documentId       String           @map("document_id")
  uploadedByUserId String?          @map("uploaded_by_user_id")
  versionLabel     String           @map("version_label")
  sourceFileName   String?          @map("source_file_name")
  storagePath      String?          @map("storage_path")
  checksumSha256   String?          @map("checksum_sha256")
  status           VersionStatus    @default(DRAFT)
  processingStatus ProcessingStatus @default(PENDING) @map("processing_status")
  pageCount        Int              @default(0) @map("page_count")
  chunkCount       Int              @default(0) @map("chunk_count")
  embeddingModel   String?          @map("embedding_model")
  publishedAt      DateTime?        @map("published_at")
  processedAt      DateTime?        @map("processed_at")
  processingError  String?          @map("processing_error")
  metadata         Json             @default("{}")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  document   TechnicalDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  uploadedBy User?             @relation("DocumentVersionUploader", fields: [uploadedByUserId], references: [id], onDelete: SetNull)
  pages      DocumentPage[]
  chunks     DocumentChunk[]
  tables     TechnicalTable[]
  normativeTables  NormativeTable[]
  normativeFigures NormativeFigure[]
  normativeNotes   NormativeNote[]
  normativeAssets  NormativeAsset[]
  abacos     TechnicalAbacus[]

  @@unique([documentId, versionLabel])
  @@index([status, processingStatus])
  @@index([uploadedByUserId])
  @@map("document_versions")
}

model DocumentPage {
  id                String   @id @default(cuid())
  documentVersionId String   @map("document_version_id")
  pageNumber        Int      @map("page_number")
  text              String?
  metadata          Json     @default("{}")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  documentVersion DocumentVersion @relation(fields: [documentVersionId], references: [id], onDelete: Cascade)
  chunks          DocumentChunk[]
  tables          TechnicalTable[]
  abacos          TechnicalAbacus[]

  @@unique([documentVersionId, pageNumber])
  @@index([pageNumber])
  @@map("document_pages")
}

model DocumentChunk {
  id                String                       @id @default(cuid())
  documentVersionId String                       @map("document_version_id")
  documentPageId    String                       @map("document_page_id")
  pageNumber        Int                          @map("page_number")
  chunkIndex        Int                          @map("chunk_index")
  text              String
  normalizedText    String?                      @map("normalized_text")
  tokenCount        Int?                         @map("token_count")
  metadata          Json                         @default("{}")
  chunkType           ChunkType                    @default(TEXT) @map("chunk_type")
  pageType            String?                      @map("page_type")
  sectionNumber       String?                      @map("section_number")
  sectionTitle        String?                      @map("section_title")
  parentSectionNumber String?                      @map("parent_section_number")
  tableNumber         String?                      @map("table_number")
  tableTitle          String?                      @map("table_title")
  technicalIntent     String?                      @map("technical_intent")
  technicalTerms      String[]                     @default([]) @map("technical_terms")
  voltageLevel        String?                      @map("voltage_level")
  topic               String?
  isTable             Boolean                      @default(false) @map("is_table")
  isFigure            Boolean                      @default(false) @map("is_figure")
  isSummary           Boolean                      @default(false) @map("is_summary")
  isCover             Boolean                      @default(false) @map("is_cover")
  isDefinition        Boolean                      @default(false) @map("is_definition")
  isRequirement       Boolean                      @default(false) @map("is_requirement")
  isProcedure         Boolean                      @default(false) @map("is_procedure")
  isSizingCriteria    Boolean                      @default(false) @map("is_sizing_criteria")
  sourceQuality       String?                      @map("source_quality")
  isSearchable        Boolean                      @default(true) @map("is_searchable")
  isLowValue          Boolean                      @default(false) @map("is_low_value")
  searchText          String?                      @map("search_text")
  embedding           Unsupported("vector(1536)")?
  embeddingModel      String?                      @map("embedding_model")
  embeddedAt          DateTime?                    @map("embedded_at")
  createdAt           DateTime                     @default(now()) @map("created_at")
  updatedAt           DateTime                     @updatedAt @map("updated_at")

  documentVersion DocumentVersion   @relation(fields: [documentVersionId], references: [id], onDelete: Cascade)
  documentPage    DocumentPage      @relation(fields: [documentPageId], references: [id], onDelete: Cascade)
  answerSources   RagAnswerSource[]

  @@unique([documentVersionId, chunkIndex])
  @@index([documentVersionId, pageNumber])
  @@index([documentPageId])
  @@index([isLowValue, isSearchable])
  @@index([chunkType])
  @@index([pageType])
  @@index([technicalIntent])
  @@index([topic])
  @@map("document_chunks")
}

model RagQuestion {
  id                  String            @id @default(cuid())
  companyId           String?           @map("company_id")
  userId              String?           @map("user_id")
  technicalDocumentId String?           @map("technical_document_id")
  question            String
  normalizedQuestion  String?           @map("normalized_question")
  status              RagQuestionStatus @default(RECEIVED)
  audience            QuestionAudience  @default(UNKNOWN)
  complexity          QuestionComplexity @default(SIMPLE)
  queryType           QueryType         @default(UNKNOWN) @map("query_type")
  accessLevel         AccessLevel       @default(FREE) @map("access_level")
  requiredProduct     BillingProduct?   @map("required_product")
  detectedTopics      String[]          @default([]) @map("detected_topics")
  detectedVoltageLevel String?          @map("detected_voltage_level")
  requiresPaidAccess  Boolean           @default(false) @map("requires_paid_access")
  missingContext      String[]          @default([]) @map("missing_context")
  metadata            Json              @default("{}")
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")

  company           Company?           @relation(fields: [companyId], references: [id], onDelete: SetNull)
  user              User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  technicalDocument TechnicalDocument? @relation(fields: [technicalDocumentId], references: [id], onDelete: SetNull)
  answer            RagAnswer?
  paidPurchases     PaidQueryPurchase[]

  @@index([companyId, createdAt])
  @@index([userId, createdAt])
  @@index([technicalDocumentId])
  @@index([status])
  @@index([audience, complexity])
  @@index([accessLevel, requiresPaidAccess])
  @@map("rag_questions")
}

model RagAnswer {
  id               String          @id @default(cuid())
  ragQuestionId    String          @unique @map("rag_question_id")
  answer           String
  status           RagAnswerStatus @default(COMPLETED)
  answerStatus     AnswerStatus    @default(DRAFT) @map("answer_status")
  accessLevel      AccessLevel     @default(FREE) @map("access_level")
  confidence       Float?
  payload          Json            @default("{}")
  modelName        String?         @map("model_name")
  promptTokens     Int?            @map("prompt_tokens")
  completionTokens Int?            @map("completion_tokens")
  totalTokens      Int?            @map("total_tokens")
  latencyMs        Int?            @map("latency_ms")
  metadata         Json            @default("{}")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  question  RagQuestion       @relation(fields: [ragQuestionId], references: [id], onDelete: Cascade)
  sources   RagAnswerSource[]
  feedbacks AnswerFeedback[]

  @@index([status])
  @@index([answerStatus])
  @@map("rag_answers")
}

model RagAnswerSource {
  id              String   @id @default(cuid())
  ragAnswerId     String   @map("rag_answer_id")
  documentChunkId String?  @map("document_chunk_id")
  pageNumber      Int      @map("page_number")
  chunkIndex      Int      @map("chunk_index")
  sourceTitle     String   @map("source_title")
  excerpt         String
  documentVersion String?  @map("document_version")
  concessionaire  String?
  stateCode       String?  @map("state_code")
  itemReference   String?  @map("item_reference")
  tableReference  String?  @map("table_reference")
  quotedText      String?  @map("quoted_text")
  relevanceScore  Float?   @map("relevance_score")
  metadata        Json     @default("{}")
  createdAt       DateTime @default(now()) @map("created_at")

  answer RagAnswer      @relation(fields: [ragAnswerId], references: [id], onDelete: Cascade)
  chunk  DocumentChunk? @relation(fields: [documentChunkId], references: [id], onDelete: SetNull)

  @@index([ragAnswerId])
  @@index([documentChunkId])
  @@index([pageNumber])
  @@map("rag_answer_sources")
}

model ProductPlan {
  id                String          @id @default(cuid())
  code              String          @unique
  name              String
  description       String?
  billingProduct    BillingProduct  @unique @map("billing_product")
  priceCents        Int             @map("price_cents")
  currency          String          @default("BRL")
  interval          BillingInterval @default(NONE)
  queryLimitMonthly Int?            @map("query_limit_monthly")
  isActive          Boolean         @default(true) @map("is_active")
  metadata          Json            @default("{}")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  subscriptions UserSubscription[]

  @@index([isActive])
  @@map("product_plans")
}

model UserSubscription {
  id                     String             @id @default(cuid())
  userId                 String?            @map("user_id")
  companyId              String?            @map("company_id")
  planId                 String             @map("plan_id")
  status                 SubscriptionStatus @default(INCOMPLETE)
  startedAt              DateTime?          @map("started_at")
  currentPeriodStart     DateTime?          @map("current_period_start")
  currentPeriodEnd       DateTime?          @map("current_period_end")
  cancelAtPeriodEnd      Boolean            @default(false) @map("cancel_at_period_end")
  externalProvider       String?            @map("external_provider")
  externalCustomerId     String?            @map("external_customer_id")
  externalSubscriptionId String?            @map("external_subscription_id")
  metadata               Json               @default("{}")
  createdAt              DateTime           @default(now()) @map("created_at")
  updatedAt              DateTime           @updatedAt @map("updated_at")

  user    User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  company Company?    @relation(fields: [companyId], references: [id], onDelete: SetNull)
  plan    ProductPlan @relation(fields: [planId], references: [id], onDelete: Restrict)

  @@index([userId, status])
  @@index([companyId, status])
  @@index([planId])
  @@index([externalProvider, externalSubscriptionId])
  @@map("user_subscriptions")
}

model QueryCredit {
  id        String            @id @default(cuid())
  userId    String?           @map("user_id")
  companyId String?           @map("company_id")
  source    QueryCreditSource
  quantity  Int
  remaining Int
  expiresAt DateTime?         @map("expires_at")
  metadata  Json              @default("{}")
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")

  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([userId, remaining])
  @@index([companyId, remaining])
  @@index([expiresAt])
  @@map("query_credits")
}

model PaidQueryPurchase {
  id                String        @id @default(cuid())
  userId            String?       @map("user_id")
  companyId         String?       @map("company_id")
  questionId        String?       @map("question_id")
  amountCents       Int           @map("amount_cents")
  currency          String        @default("BRL")
  status            PaymentStatus @default(PENDING)
  externalProvider  String?       @map("external_provider")
  externalPaymentId String?       @map("external_payment_id")
  metadata          Json          @default("{}")
  createdAt         DateTime      @default(now()) @map("created_at")

  user     User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  company  Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)
  question RagQuestion? @relation(fields: [questionId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([companyId, status])
  @@index([questionId])
  @@index([externalProvider, externalPaymentId])
  @@map("paid_query_purchases")
}

model TechnicalTable {
  id                String           @id @default(cuid())
  documentVersionId String           @map("document_version_id")
  documentPageId    String?          @map("document_page_id")
  title             String
  tableNumber       String?          @map("table_number")
  normalizedTitle   String           @map("normalized_title")
  category          DocumentCategory
  pageNumber        Int              @map("page_number")
  itemReference     String?          @map("item_reference")
  rawText           String?          @map("raw_text")
  metadata          Json             @default("{}")
  createdAt         DateTime         @default(now()) @map("created_at")

  documentVersion DocumentVersion @relation(fields: [documentVersionId], references: [id], onDelete: Cascade)
  documentPage    DocumentPage?   @relation(fields: [documentPageId], references: [id], onDelete: SetNull)
  rows            TechnicalTableRow[]

  @@index([documentVersionId])
  @@index([documentPageId])
  @@index([category])
  @@index([pageNumber])
  @@map("technical_tables")
}

model TechnicalTableRow {
  id               String   @id @default(cuid())
  technicalTableId String   @map("technical_table_id")
  rowIndex         Int      @map("row_index")
  data             Json
  normalizedData   Json     @map("normalized_data")
  createdAt        DateTime @default(now()) @map("created_at")

  technicalTable TechnicalTable @relation(fields: [technicalTableId], references: [id], onDelete: Cascade)

  @@unique([technicalTableId, rowIndex])
  @@map("technical_table_rows")
}

model NormativeTable {
  id                String   @id @default(cuid())
  assetId           String?  @map("asset_id")
  documentVersionId String   @map("document_version_id")
  documentId        String   @map("document_id")
  tableNumber       String?  @map("table_number")
  title             String
  pageNumber        Int      @map("page_number")
  concessionaire    String?
  state             String?
  voltage           String?
  category          String?
  validationStatus  String   @default("PENDING") @map("validation_status")
  validationNotes   String?  @map("validation_notes")
  validatedAt       DateTime? @map("validated_at")
  applicableVoltage String?  @map("applicable_voltage")
  applicableSupplyType String? @map("applicable_supply_type")
  unitBasis         String?  @map("unit_basis")
  tableNotes        String?  @map("table_notes")
  sourceText        String?  @map("source_text")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  asset           NormativeAsset? @relation(fields: [assetId], references: [id], onDelete: SetNull)
  documentVersion DocumentVersion @relation(fields: [documentVersionId], references: [id], onDelete: Cascade)
  rows            NormativeTableRow[]
  notes           NormativeNote[]

  @@index([documentVersionId])
  @@index([documentId])
  @@index([assetId])
  @@index([tableNumber])
  @@index([state, voltage])
  @@map("normative_tables")
}

model NormativeAsset {
  id                String                          @id @default(cuid())
  documentId        String                          @map("document_id")
  documentVersionId String                          @map("document_version_id")
  type              NormativeAssetType
  title             String
  code              String?
  pageNumber        Int                             @map("page_number")
  imageStoragePath  String?                         @map("image_storage_path")
  extractedText     String?                         @map("extracted_text")
  structuredDataJson Json                            @default("{}") @map("structured_data_json")
  validationStatus  NormativeAssetValidationStatus  @default(PENDING) @map("validation_status")
  validatedByUserId String?                         @map("validated_by_user_id")
  validatedAt       DateTime?                       @map("validated_at")
  isActive          Boolean                         @default(true) @map("is_active")
  concessionaire    String?
  state             String?
  voltageLevel      String?                         @map("voltage_level")
  tags              String[]                        @default([])
  createdAt         DateTime                        @default(now()) @map("created_at")
  updatedAt         DateTime                        @updatedAt @map("updated_at")

  documentVersion DocumentVersion @relation(fields: [documentVersionId], references: [id], onDelete: Cascade)
  validatedBy     User?           @relation("NormativeAssetValidator", fields: [validatedByUserId], references: [id], onDelete: SetNull)
  tables          NormativeTable[]
  figures         NormativeFigure[]

  @@index([documentVersionId])
  @@index([documentId])
  @@index([type])
  @@index([validationStatus])
  @@index([isActive])
  @@index([code])
  @@map("normative_assets")
}

model NormativeFigure {
  id                String   @id @default(cuid())
  assetId           String?  @map("asset_id")
  documentVersionId String   @map("document_version_id")
  documentId        String   @map("document_id")
  figureNumber      String?  @map("figure_number")
  title             String
  pageNumber        Int      @map("page_number")
  imageStoragePath  String?  @map("image_storage_path")
  description       String?
  figureType        String?  @map("figure_type")
  topic             String?
  voltage           String?
  serviceType       String?  @map("service_type")
  relatedTableNumber String? @map("related_table_number")
  sourceText        String?  @map("source_text")
  metadata          Json     @default("{}")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  asset           NormativeAsset? @relation(fields: [assetId], references: [id], onDelete: SetNull)
  documentVersion DocumentVersion @relation(fields: [documentVersionId], references: [id], onDelete: Cascade)
  items           NormativeFigureItem[]
  notes           NormativeNote[]

  @@index([documentVersionId])
  @@index([documentId])
  @@index([assetId])
  @@index([figureNumber])
  @@index([relatedTableNumber])
  @@map("normative_figures")
}

model NormativeFigureItem {
  id             String   @id @default(cuid())
  figureId       String   @map("figure_id")
  itemCode       String?  @map("item_code")
  itemNumber     String?  @map("item_number")
  description    String
  quantity       String?
  hasAsterisk    Boolean  @default(false) @map("has_asterisk")
  responsibility String   @default("NAO_INFORMADO")
  relatedTable   String?  @map("related_table")
  notes          String?
  rawText        String?  @map("raw_text")
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  figure NormativeFigure @relation(fields: [figureId], references: [id], onDelete: Cascade)

  @@index([figureId])
  @@index([responsibility])
  @@map("normative_figure_items")
}

model NormativeNote {
  id                String   @id @default(cuid())
  documentVersionId String   @map("document_version_id")
  documentId        String   @map("document_id")
  tableId           String?  @map("table_id")
  figureId          String?  @map("figure_id")
  noteNumber        String?  @map("note_number")
  noteType          String   @map("note_type")
  title             String?
  text              String
  measurementName   String?  @map("measurement_name")
  value             Float?
  tolerance         Float?
  unit              String?
  minValue          Float?   @map("min_value")
  maxValue          Float?   @map("max_value")
  pageNumber        Int      @map("page_number")
  metadata          Json     @default("{}")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  documentVersion DocumentVersion @relation(fields: [documentVersionId], references: [id], onDelete: Cascade)
  table           NormativeTable? @relation(fields: [tableId], references: [id], onDelete: Cascade)
  figure          NormativeFigure? @relation(fields: [figureId], references: [id], onDelete: Cascade)

  @@index([documentVersionId])
  @@index([documentId])
  @@index([tableId])
  @@index([figureId])
  @@index([noteType])
  @@index([noteNumber])
  @@map("normative_notes")
}

model NormativeTableRow {
  id                              String   @id @default(cuid())
  tableId                         String   @map("table_id")
  rowIndex                        Int      @map("row_index")
  method                          String?
  supplyType                      String?  @map("supply_type")
  loadMinKw                       Float?   @map("load_min_kw")
  loadMaxKw                       Float?   @map("load_max_kw")
  loadMinKva                      Float?   @map("load_min_kva")
  loadMaxKva                      Float?   @map("load_max_kva")
  voltage                         String?
  breakerAmp                      Int?     @map("breaker_amp")
  breakerA                        Int?     @map("breaker_a")
  breakerType                     String?  @map("breaker_type")
  copperCableMm2                  Float?   @map("copper_cable_mm2")
  aluminumCableMm2                Float?   @map("aluminum_cable_mm2")
  concentricCableMm2              Float?   @map("concentric_cable_mm2")
  copperConcentricMm2             Float?   @map("copper_concentric_mm2")
  copperMultiplexedMm2            Float?   @map("copper_multiplexed_mm2")
  aluminumDuplexMm2               Float?   @map("aluminum_duplex_mm2")
  aluminumTriplexMm2              Float?   @map("aluminum_triplex_mm2")
  aluminumQuadruplexMm2           Float?   @map("aluminum_quadruplex_mm2")
  galvanizedSteelConduitInch      String?  @map("galvanized_steel_conduit_inch")
  customerPhaseNeutralConductorMm2 Float?  @map("customer_phase_neutral_conductor_mm2")
  groundingConductorMm2           Float?   @map("grounding_conductor_mm2")
  conduitDiameter                 String?  @map("conduit_diameter")
  groundingConduitDiameter        String?  @map("grounding_conduit_diameter")
  groundingConduitInch            String?  @map("grounding_conduit_inch")
  notes                           String?
  rawRowJson                      Json     @default("{}") @map("raw_row_json")
  rawText                         String?  @map("raw_text")
  sourcePage                      Int?     @map("source_page")
  sourceText                      String?  @map("source_text")
  pageNumber                      Int      @map("page_number")
  createdAt                       DateTime @default(now()) @map("created_at")
  updatedAt                       DateTime @updatedAt @map("updated_at")

  table NormativeTable @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@unique([tableId, rowIndex])
  @@index([tableId])
  @@index([voltage, supplyType])
  @@index([loadMinKw, loadMaxKw])
  @@map("normative_table_rows")
}

model TechnicalAbacus {
  id                String           @id @default(cuid())
  documentVersionId String           @map("document_version_id")
  documentPageId    String?          @map("document_page_id")
  title             String
  abacusNumber      String?          @map("abacus_number")
  category          DocumentCategory
  pageNumber        Int              @map("page_number")
  itemReference     String?          @map("item_reference")
  description       String?
  rawText           String?          @map("raw_text")
  metadata          Json             @default("{}")
  createdAt         DateTime         @default(now()) @map("created_at")

  documentVersion DocumentVersion @relation(fields: [documentVersionId], references: [id], onDelete: Cascade)
  documentPage    DocumentPage?   @relation(fields: [documentPageId], references: [id], onDelete: SetNull)

  @@index([documentVersionId])
  @@index([documentPageId])
  @@index([category])
  @@index([pageNumber])
  @@map("technical_abacuses")
}

model TechnicalRule {
  id                  String                  @id @default(cuid())
  sourceType          TechnicalRuleSourceType @map("source_type")
  sourceId            String                  @map("source_id")
  concessionaire      String?
  stateCode           String?                 @map("state_code")
  category            DocumentCategory
  voltageLevel        String?                 @map("voltage_level")
  application         String?
  conditionJson       Json                    @map("condition_json")
  resultJson          Json                    @map("result_json")
  sourceDocumentTitle String?                 @map("source_document_title")
  sourcePageNumber    Int?                    @map("source_page_number")
  sourceItemReference String?                 @map("source_item_reference")
  confidence          Float?
