  @@index([sourceType, sourceId])
  @@index([concessionaire, stateCode])
  @@index([category])
  @@index([status])
  @@map("technical_rules")
}

model AnswerFeedback {
  id                  String             @id @default(cuid())
  answerId            String             @map("answer_id")
  userId              String?            @map("user_id")
  rating              Int?
  feedbackType        AnswerFeedbackType @map("feedback_type")
  comment             String?
  suggestedCorrection String?            @map("suggested_correction")
  createdAt           DateTime           @default(now()) @map("created_at")

  answer RagAnswer @relation(fields: [answerId], references: [id], onDelete: Cascade)
  user   User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([answerId])
  @@index([userId])
  @@index([feedbackType])
  @@map("answer_feedback")
}

model ValidatedAnswer {
  id                String           @id @default(cuid())
  questionPattern   String           @map("question_pattern")
  normalizedQuestion String          @map("normalized_question")
  answerPayload     Json             @map("answer_payload")
  validatedByUserId String?          @map("validated_by_user_id")
  validationStatus  ValidationStatus @default(DRAFT) @map("validation_status")
  sourceIds         Json             @map("source_ids")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  validatedBy User? @relation("ValidatedAnswerReviewer", fields: [validatedByUserId], references: [id], onDelete: SetNull)

  @@index([validationStatus])
  @@index([validatedByUserId])
  @@map("validated_answers")
}

model AuditLog {
  id         String      @id @default(cuid())
  companyId  String?     @map("company_id")
  userId     String?     @map("user_id")
  action     AuditAction
  entityType String      @map("entity_type")
  entityId   String?     @map("entity_id")
  ipAddress  String?     @map("ip_address")
  userAgent  String?     @map("user_agent")
  metadata   Json        @default("{}")
  createdAt  DateTime    @default(now()) @map("created_at")

  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt])
  @@index([userId, createdAt])
  @@index([action])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

model PlanUsage {
  id          String           @id @default(cuid())
  companyId   String           @map("company_id")
  plan        SubscriptionPlan
  metric      UsageMetric
  quantity    Int              @default(0)
  limit       Int?
  periodStart DateTime         @map("period_start")
  periodEnd   DateTime         @map("period_end")
  metadata    Json             @default("{}")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, metric, periodStart, periodEnd])
  @@index([companyId, plan])
  @@index([metric])
  @@map("plan_usages")
}
